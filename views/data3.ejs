<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Aura Music</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.3.0/fonts/remixicon.css" rel="stylesheet"/>
    <style>
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
        :root{
            --bg:#121212;--s1:#1a1a1a;--s2:#242424;--s3:#2a2a2a;--s4:#3e3e3e;
            --border:rgba(255,255,255,0.08);
            --green:#1db954;
            --text:#ffffff;--text2:#b3b3b3;--text3:#535353;
            --nav-h:65px;--mini-h:68px;--topbar-h:56px;
            --r:12px;--rs:8px;
            --sib: env(safe-area-inset-bottom, 0px);
        }
        html,body{height:100%;height:100dvh;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;overflow:hidden;-webkit-font-smoothing:antialiased}
        button{font-family:'DM Sans',sans-serif;cursor:pointer;-webkit-appearance:none;border:none;background:none}
        input{font-family:'DM Sans',sans-serif;-webkit-appearance:none}
        ::-webkit-scrollbar{display:none}
        *{scrollbar-width:none}

        #app{display:flex;height:100dvh;overflow:hidden;position:relative}

        /* SIDEBAR (Desktop) */
        #sidebar{
            width:260px;background:#000;border-right:1px solid var(--border);
            display:none;flex-direction:column;height:100dvh;flex-shrink:0;
            overflow:hidden;
        }
        @media(min-width:768px){
            #sidebar{display:flex}
            #bottom-nav{display:none!important}
            #topbar{display:none!important}
            #content{padding-bottom:calc(var(--mini-h) + 20px + var(--sib))!important}
            #mini-player{left:268px!important;right:8px!important;bottom:calc(8px + var(--sib))!important}
        }
        .sd-logo{padding:24px 20px 18px;display:flex;align-items:center;gap:10px;flex-shrink:0}
        .sd-logo-mark{width:36px;height:36px;background:var(--green);border-radius:10px;display:flex;align-items:center;justify-content:center;color:#000;font-size:20px}
        .sd-logo-text{font-size:20px;font-weight:800;letter-spacing:-0.5px}
        .sd-nav{padding:8px;flex-shrink:0}
        .sd-btn{display:flex;align-items:center;gap:14px;padding:12px 14px;border-radius:8px;color:var(--text2);width:100%;font-size:15px;font-weight:700;transition:0.2s}
        .sd-btn i{font-size:22px}
        .sd-btn:hover,.sd-btn.active{background:var(--s2);color:var(--text)}
        .sd-pl-wrap{flex:1;overflow-y:auto;padding:8px;min-height:0}
        .sd-section-lbl{font-size:11px;font-weight:700;letter-spacing:1.2px;color:var(--text3);text-transform:uppercase;padding:16px 14px 8px}
        
        /* MAIN CONTENT */
        #main-col{display:flex;flex-direction:column;flex:1;overflow:hidden;min-width:0;position:relative}
        #topbar{height:var(--topbar-h);background:rgba(18,18,18,0.8);backdrop-filter:blur(10px);display:flex;align-items:center;justify-content:space-between;padding:0 16px;z-index:10}
        .tb-title-group{display:flex; flex-direction:column;}
        .tb-title{font-size:18px;font-weight:800}
        .tb-subtitle{font-size:10px; color:var(--text3); font-weight:700; text-transform:uppercase; letter-spacing:1px; margin-top:-2px;}
        .ico-btn{color:var(--text);padding:8px;border-radius:50%;display:flex;align-items:center;justify-content:center;transition:0.15s}
        .ico-btn:active{background:rgba(255,255,255,0.1)}

        #content{flex:1;overflow-y:auto;padding-bottom:calc(var(--mini-h) + var(--nav-h) + 20px + var(--sib));-webkit-overflow-scrolling:touch}
        .view{display:none;padding:16px}
        .view.active{display:block}

        /* GRID FOR ARTISTS */
        .artist-grid {
            display: flex;
            gap: 16px;
            overflow-x: auto;
            padding-bottom: 10px;
            margin-bottom: 30px;
        }
        .artist-card {
            flex-shrink: 0;
            width: 100px;
            text-align: center;
            cursor: pointer;
        }
        .artist-thumb {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            margin: 0 auto 10px;
            background: var(--s2);
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.4);
            border: 2px solid var(--border);
        }
        .artist-thumb img { width: 100%; height: 100%; object-fit: cover; }
        .artist-name { font-size: 13px; font-weight: 700; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        /* LIST ITEMS */
        .tl-item{display:flex;align-items:center;gap:14px;padding:10px 0;cursor:pointer;border-radius:8px;transition:0.12s}
        .tl-item:active{background:rgba(255,255,255,0.05);transform:scale(0.98)}
        .tl-thumb{width:56px;height:56px;border-radius:var(--rs);background:var(--s2);display:flex;align-items:center;justify-content:center;font-size:22px;color:var(--green);flex-shrink:0;position:relative;overflow:hidden;box-shadow: 0 4px 10px rgba(0,0,0,0.3);}
        .tl-thumb img{width:100%; height:100%; object-fit:cover;}
        .tl-info{flex:1;min-width:0}
        .tl-name{font-size:15px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
        .tl-name.active{color:var(--green)}
        .tl-artist{font-size:13px;color:var(--text2);margin-top:2px}
        .tl-more{color:var(--text3);padding:10px}

        /* MINI PLAYER */
        #mini-player{
            position:fixed;bottom:calc(var(--nav-h) + var(--sib) + 6px);left:8px;right:8px;
            height:var(--mini-h);background:#282828;border-radius:12px;
            display:none;align-items:center;padding:0 12px;gap:12px;z-index:50;
            box-shadow:0 8px 24px rgba(0,0,0,0.5);
        }
        #mini-player.show{display:flex}
        .mp-prog{position:absolute;bottom:0;left:12px;right:12px;height:2px;background:rgba(255,255,255,0.1);border-radius:1px}
        .mp-fill{height:100%;background:var(--text);border-radius:1px;width:0%}

        /* FULL PLAYER */
        #full-player{
            position:fixed;inset:0;background:linear-gradient(180deg,#333 0%,#121212 100%);
            z-index:100;display:flex;flex-direction:column;transform:translateY(100%);
            transition:transform 0.4s cubic-bezier(0.3, 1, 0.3, 1);
        }
        #full-player.open{transform:translateY(0)}
        .fp-hdr{display:flex;align-items:center;justify-content:space-between;padding:16px 20px}
        .fp-art-wrap{flex:1;display:flex;align-items:center;justify-content:center;padding:20px}
        .fp-art{width:80vw;max-width:320px;aspect-ratio:1;background:var(--s2);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:100px;box-shadow:0 20px 50px rgba(0,0,0,0.5); overflow:hidden;}
        .fp-art img{width:100%; height:100%; object-fit:cover;}
        .fp-info{padding:0 30px 20px}
        .fp-title{font-size:24px;font-weight:800;margin-bottom:4px}
        .fp-artist{font-size:16px;color:var(--text2);font-weight:500}
        .fp-prog-wrap{padding:0 30px 10px}
        .fp-bar-bg{height:4px;background:rgba(255,255,255,0.1);border-radius:2px;position:relative;cursor:pointer}
        .fp-bar-fill{height:100%;background:#fff;border-radius:2px;width:0%}
        .fp-time{display:flex;justify-content:space-between;margin-top:8px;font-size:12px;color:var(--text2);font-weight:600}
        .fp-controls{display:flex;align-items:center;justify-content:space-between;padding:10px 30px 40px}
        .fp-btn-main{width:64px;height:64px;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#000;font-size:30px}

        /* BOTTOM NAV */
        #bottom-nav{
            position:fixed;bottom:0;left:0;right:0;height:calc(var(--nav-h) + var(--sib));
            background:rgba(18,18,18,0.95);backdrop-filter:blur(15px);
            display:flex;align-items:flex-start;padding-top:8px;z-index:40;border-top:1px solid var(--border);
        }
        .nav-item{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;color:var(--text3);font-weight:700}
        .nav-item.active{color:var(--text)}
        .nav-item i{font-size:24px}
        .nav-item span{font-size:10px}

        /* MODALS */
        .overlay{position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:200;display:none;align-items:center;justify-content:center;padding:20px}
        .modal{background:var(--s2);border-radius:16px;padding:24px;width:100%;max-width:340px;text-align:center}
        .modal input{width:100%;background:var(--s3);border:1px solid var(--border);border-radius:8px;padding:12px;color:#fff;margin:16px 0;font-size:16px}
        .m-btns{display:flex;gap:12px}
        .m-btn{flex:1;padding:12px;border-radius:50px;font-weight:700;font-size:15px}
        .m-btn.primary{background:var(--green);color:#000}
        .m-btn.secondary{background:var(--s3);color:#fff}

        /* BOTTOM SHEET */
        .sheet-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:210;display:none}
        .sheet{position:fixed;bottom:0;left:0;right:0;background:#282828;border-radius:16px 16px 0 0;z-index:220;transform:translateY(100%);transition:0.3s ease;padding:10px 0 calc(20px + var(--sib))}
        .sheet.open{transform:translateY(0)}
        .sheet-h{width:40px;height:4px;background:rgba(255,255,255,0.2);border-radius:2px;margin:0 auto 15px}
        .sheet-item{display:flex;align-items:center;gap:16px;padding:14px 24px;font-size:16px;font-weight:600;color:var(--text);transition:0.1s}
        .sheet-item:active{background:rgba(255,255,255,0.05)}
        .sheet-item i{font-size:22px;color:var(--text2)}
        .sheet-track{display:flex;align-items:center;gap:14px;padding:10px 24px 20px;border-bottom:1px solid var(--border);margin-bottom:10px}
        .st-thumb{width:48px;height:48px;border-radius:6px;background:var(--s3);display:flex;align-items:center;justify-content:center;font-size:20px; overflow:hidden;}
        .st-thumb img{width:100%; height:100%; object-fit:cover;}

        .visitor-footer {
            padding: 40px 20px 20px;
            text-align: center;
            color: var(--text3);
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            opacity: 0.8;
        }
    </style>
</head>
<body>
<div id="app">
    <!-- SIDEBAR -->
    <aside id="sidebar">
        <div class="sd-logo">
            <div class="sd-logo-mark"><i class="ri-music-fill"></i></div>
            <span class="sd-logo-text">Aura Music</span>
        </div>
        <nav class="sd-nav">
            <button class="sd-btn active" onclick="nav('home')"><i class="ri-home-5-fill"></i> Home</button>
            <button class="sd-btn" onclick="nav('search')"><i class="ri-search-line"></i> Search</button>
            <button class="sd-btn" onclick="nav('library')"><i class="ri-play-list-2-fill"></i> Library</button>
        </nav>
        <div class="sd-section-lbl">Your Playlists</div>
        <div class="sd-pl-wrap" id="sd-pl-list"></div>
        <button class="sd-btn" onclick="openModal('playlist')"><i class="ri-add-box-fill"></i> Create New</button>
    </aside>

    <!-- MAIN -->
    <main id="main-col">
        <header id="topbar">
            <div class="tb-title-group">
                <div class="tb-title" id="tb-title">Aura</div>
                <div class="tb-subtitle" id="tb-count">0 Tracks</div>
            </div>
            <div style="display:flex; gap:8px;">
                <a href="/postmp3" style="text-decoration:none;">
                    <button class="ico-btn"><i class="ri-add-line" style="font-size:22px;"></i></button>
                </a>
                <button class="ico-btn"><i class="ri-notification-3-line" style="font-size:22px;"></i></button>
            </div>
        </header>

        <section id="content">
            <!-- HOME VIEW -->
            <div class="view active" id="view-home">
                <h2 style="margin:8px 0 20px; font-size:24px; font-weight:800;">Good evening 👋</h2>
                
                <div id="artist-album-section" style="display:none;">
                    <h3 style="font-size:18px; font-weight:700; color:var(--text2); margin-bottom:14px; text-transform:uppercase; letter-spacing:1px;">Featured Artists</h3>
                    <div class="artist-grid" id="artist-grid"></div>
                </div>

                <h3 style="font-size:18px; font-weight:700; color:var(--text2); margin-bottom:14px; text-transform:uppercase; letter-spacing:1px;">Just for you</h3>
                <div id="home-list"></div>
                <div id="home-visitor-footer" class="visitor-footer"></div>
            </div>

            <!-- SEARCH VIEW -->
            <div class="view" id="view-search">
                <div class="search-box">
                    <i class="ri-search-line" style="color:#000; font-size:20px; margin-left:12px;"></i>
                    <input id="search-inp" type="text" placeholder="Search songs, artists..." oninput="filterSongs()" style="background:#fff; border-radius:8px; padding:12px; border:none; outline:none; font-size:16px; font-weight:600; flex:1;">
                </div>
                <div id="search-list"></div>
            </div>

            <!-- LIBRARY VIEW -->
            <div class="view" id="view-library">
                <h2 style="margin-bottom:20px; font-size:24px; font-weight:800;">Your Library</h2>
                <div id="lib-list"></div>
            </div>

            <!-- PLAYLIST VIEW -->
            <div class="view" id="view-playlist">
                <div id="pl-hdr" style="margin-bottom:24px; text-align:center;">
                    <div id="pl-thumb" style="width:160px; height:160px; background:var(--s2); border-radius:12px; margin:0 auto 15px; display:flex; align-items:center; justify-content:center; font-size:60px; box-shadow:0 15px 40px rgba(0,0,0,0.5); overflow:hidden;">🎶</div>
                    <h2 id="pl-name" style="font-size:28px; font-weight:800;">Playlist Name</h2>
                    <p id="pl-meta" style="color:var(--text2); font-size:14px; font-weight:600; margin-top:5px;">0 songs</p>
                </div>
                <div id="pl-list"></div>
            </div>

             <!-- ARTIST DETAIL VIEW -->
             <div class="view" id="view-artist-detail">
                <div id="ad-hdr" style="margin-bottom:24px; text-align:center;">
                    <div id="ad-thumb" style="width:140px; height:140px; background:var(--s2); border-radius:50%; margin:0 auto 15px; overflow:hidden; box-shadow:0 15px 40px rgba(0,0,0,0.5); border: 3px solid var(--border);"></div>
                    <h2 id="ad-name" style="font-size:28px; font-weight:800;">Artist Name</h2>
                    <p id="ad-meta" style="color:var(--text2); font-size:14px; font-weight:600; margin-top:5px;">Collection</p>
                </div>
                <div id="ad-list"></div>
            </div>
        </section>

        <!-- MINI PLAYER -->
        <div id="mini-player" onclick="openFullPlayer()">
            <div class="mp-prog"><div class="mp-fill" id="mp-fill"></div></div>
            <div id="mp-thumb-container" style="width:44px; height:44px; background:var(--s3); border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:20px; overflow:hidden;">🎵</div>
            <div style="flex:1; min-width:0;">
                <div id="mp-title" style="font-size:14px; font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">No song playing</div>
                <div id="mp-artist" style="font-size:12px; color:var(--text2); font-weight:600;">—</div>
            </div>
            <button class="ico-btn" onclick="togglePlay(event)" style="font-size:28px; color:#fff;"><i class="ri-play-fill" id="mp-play-ico"></i></button>
        </div>

        <!-- MOBILE NAV -->
        <nav id="bottom-nav">
            <button class="nav-item active" onclick="nav('home')"><i class="ri-home-5-fill"></i><span>Home</span></button>
            <button class="nav-item" onclick="nav('search')"><i class="ri-search-line"></i><span>Search</span></button>
            <button class="nav-item" onclick="nav('library')"><i class="ri-play-list-2-line"></i><span>Library</span></button>
            <button class="nav-item" onclick="openModal('playlist')"><i class="ri-add-box-line"></i><span>Create</span></button>
        </nav>
    </main>
</div>

<!-- FULL PLAYER SCREEN -->
<div id="full-player">
    <div class="fp-hdr">
        <button class="ico-btn" onclick="closeFullPlayer()"><i class="ri-arrow-down-s-line" style="font-size:30px;"></i></button>
        <span style="font-size:12px; font-weight:800; letter-spacing:1px; text-transform:uppercase;">Now Playing</span>
        <button class="ico-btn"><i class="ri-more-2-fill" style="font-size:24px;"></i></button>
    </div>
    <div class="fp-art-wrap">
        <div class="fp-art" id="fp-art">🎵</div>
    </div>
    <div class="fp-info">
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <div>
                <div class="fp-title" id="fp-title">No Track</div>
                <div class="fp-artist" id="fp-artist">—</div>
            </div>
            <button class="ico-btn" onclick="toggleLike()" id="fp-like-btn" style="font-size:28px;"><i class="ri-heart-line"></i></button>
        </div>
    </div>
    <div class="fp-prog-wrap">
        <div class="fp-bar-bg" onclick="seekAt(event)">
            <div class="fp-bar-fill" id="fp-fill-lg"></div>
        </div>
        <div class="fp-time">
            <span id="fp-cur">0:00</span>
            <span id="fp-dur">0:00</span>
        </div>
    </div>
    <div class="fp-controls">
        <button class="ico-btn" onclick="toggleShuffle()" id="fp-shuf" style="font-size:22px;"><i class="ri-shuffle-line"></i></button>
        <button class="ico-btn" onclick="prevTrack()" style="font-size:32px;"><i class="ri-skip-back-mini-fill"></i></button>
        <button class="fp-btn-main" onclick="togglePlay()"><i class="ri-play-fill" id="fp-play-ico"></i></button>
        <button class="ico-btn" onclick="nextTrack()" style="font-size:32px;"><i class="ri-skip-forward-mini-fill"></i></button>
        <button class="ico-btn" onclick="toggleLoop()" id="fp-loop" style="font-size:22px;"><i class="ri-repeat-line"></i></button>
    </div>
</div>

<!-- MODAL -->
<div class="overlay" id="modal-bg">
    <div class="modal">
        <h3 id="modal-title">New Playlist</h3>
        <input type="text" id="modal-inp" placeholder="Name yours...">
        <div class="m-btns">
            <button class="m-btn secondary" onclick="closeModal()">Cancel</button>
            <button class="m-btn primary" onclick="confirmModal()">Confirm</button>
        </div>
    </div>
</div>

<!-- SHEET -->
<div class="sheet-overlay" id="sheet-bg" onclick="closeSheet()"></div>
<div class="sheet" id="sheet">
    <div class="sheet-h"></div>
    <div id="sheet-body"></div>
</div>

<div id="toast"></div>
<audio id="aud"></audio>

<script>
    // --- SAMPLE DATA INTEGRATION ---
