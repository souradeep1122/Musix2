    const rawFilesFromEnv = <%- typeof files !== 'undefined' ? JSON.stringify(files) : '[]' %>;
    const visitCount = <%= typeof visitorCount !== 'undefined' ? visitorCount : '0' %>;

    // Visual Assets
    const CARD_IMAGES = [
        "https://images.unsplash.com/photo-1470225620780-dba8ba36b745?q=80&w=400&auto=format&fit=crop",
        "https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?q=80&w=400&auto=format&fit=crop",
        "https://plus.unsplash.com/premium_photo-1677589330308-935750583375?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8OTR8fG11c2ljJTIwd2FsbHBhcGVyfGVufDB8fDB8fHww",
        "https://plus.unsplash.com/premium_photo-1723924899327-48f529ba853b?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8NTh8fG11c2ljJTIwd2FsbHBhcGVyfGVufDB8fDB8fHww",
        "https://plus.unsplash.com/premium_photo-1682125511152-549a67b66c4a?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTE0fHxtdXNpYyUyMHdhbGxwYXBlcnxlbnwwfHwwfHx8MA%3D%3D",
        "https://plus.unsplash.com/premium_photo-1677155842676-8e13e7053844?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MjA0fHxtdXNpYyUyMHdhbGxwYXBlcnxlbnwwfHwwfHx8MA%3D%3D",
        "https://images.unsplash.com/photo-1631246974502-73131bdaa3cf?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MjIzfHxtdXNpYyUyMHdhbGxwYXBlcnxlbnwwfHwwfHx8MA%3D%3D",
        "https://images.unsplash.com/photo-1599351430174-1cb440fadb07?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MjI1fHxtdXNpYyUyMHdhbGxwYXBlcnxlbnwwfHwwfHx8MA%3D%3D",
        "https://images.unsplash.com/photo-1650472740228-e83ea26961a5?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MjM4fHxtdXNpYyUyMHdhbGxwYXBlcnxlbnwwfHwwfHx8MA%3D%3D",
        "https://plus.unsplash.com/premium_photo-1677159499898-b061fb5bd2d7?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MjU4fHxtdXNpYyUyMHdhbGxwYXBlcnxlbnwwfHwwfHx8MA%3D%3D",
        "https://plus.unsplash.com/premium_photo-1679864782395-cc5697bf614f?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MjY2fHxtdXNpYyUyMHdhbGxwYXBlcnxlbnwwfHwwfHx8MA%3D%3D",
        "https://images.unsplash.com/photo-1707201927404-bf631c937ac5?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8Mzc4fHxtdXNpYyUyMHdhbGxwYXBlcnxlbnwwfHwwfHx8MA%3D%3D",
        "https://plus.unsplash.com/premium_photo-1767993206413-e4f6c06bedfc?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8NTQyfHxtdXNpYyUyMHdhbGxwYXBlcnxlbnwwfHwwfHx8MA%3D%3D",
        "https://images.unsplash.com/photo-1518893883800-45cd0954574b?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8NTk4fHxtdXNpYyUyMHdhbGxwYXBlcnxlbnwwfHwwfHx8MA%3D%3D",
    ];

    // --- CLEANING LOGIC ---
    function cleanMetadata(str) {
        if (!str) return { title: "Unknown", artist: "Aura Artist" };
        
        let name = str;
        
        // 1. Strip out website patterns in parentheses like (PagalWorldi.com.co)
        name = name.replace(/\(.*?\)/g, '');

        // 2. Handle specific complex separators like "-Mp3-Song-by-" or "-by-"
        name = name.replace(/-Mp3-Song-by-/gi, ' by ');
        name = name.replace(/Mp3-Song-by-/gi, ' by ');
        name = name.replace(/-by-/gi, ' by ');
        name = name.replace(/Mp3 Song by/gi, ' by ');

        // 3. Replace all remaining underscores and dashes with spaces
        name = name.replace(/[_-]/g, ' ');

        // 4. Remove bitrates and other unwanted artifacts
        name = name.replace(/\s*[(\[][^)\]]*(official|video|lyrics|audio|kbps|\d+k|www\.|@|hq|com|co)[^)\]]*[)\]]/gi, '');
        
        // 5. Cleanup extra whitespace
        name = name.replace(/\s+/g, ' ').trim();

        let title = "", artist = "Aura Artist";
        
        // Try multiple splitters to find Artist
        const separators = [/ by /i, / — /, / - /];
        let found = false;
        
        for (let sep of separators) {
            if (name.match(sep)) {
                const parts = name.split(sep);
                title = parts[0].trim();
                artist = parts[1].trim();
                found = true;
                break;
            }
        }

        if (!found) {
            title = name;
        }
        
        return { title, artist };
    }

    const allSongs = [];
    const sourceData = rawFilesFromEnv.length > 0 ? rawFilesFromEnv : RAW_MUSIC_DATA;

    sourceData.forEach((item, i) => {
        let meta;
        let public_id, url;

        if (typeof item === 'string') {
            meta = cleanMetadata(item);
            public_id = 'sample_' + i;
            url = "#";
        } else {
            // Clean the original filename
            meta = cleanMetadata(item.originalname.replace(/\.[^.]+$/, ''));
            public_id = item.public_id;
            url = item.url;
        }

        allSongs.push({
            title: meta.title,
            artist: meta.artist,
            public_id,
            url,
            imgUrl: CARD_IMAGES[i % CARD_IMAGES.length],
            artistImgUrl: `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(meta.artist)}&backgroundColor=1db954&fontSize=40`
        });
    });

    // Auto-Group Artist Albums (appeared >= 2 times)
    const artistMap = {};
    allSongs.forEach(s => {
        if (!artistMap[s.artist]) artistMap[s.artist] = [];
        artistMap[s.artist].push(s);
    });

    const artistAlbums = Object.entries(artistMap)
        .filter(([name, tracks]) => tracks.length >= 2 && name !== "Aura Artist")
        .map(([name, tracks]) => ({
            name,
            tracks,
            id: 'artist_' + btoa(name).substring(0, 8),
            imgUrl: `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(name)}&backgroundColor=1db954`
        }));

    // --- APP STATE ---
    const S = {
        queue: [...allSongs],
        idx: -1,
        playing: false,
        shuffle: false,
        loop: false,
        liked: new Set(JSON.parse(localStorage.getItem('auraLikes')) || []),
        playlists: JSON.parse(localStorage.getItem('auraPlaylists')) || [],
        tab: 'home',
        activePlId: null,
        activeArtistId: null,
        targetSongId: null
    };

    const aud = document.getElementById('aud');

    // --- NAV ---
    function nav(name) {
        S.tab = name;
        document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
        const targetView = document.getElementById('view-' + name);
        if (targetView) targetView.classList.add('active');
        
        document.querySelectorAll('.nav-item').forEach(b => b.classList.toggle('active', b.getAttribute('onclick')?.includes(`'${name}'`)));
        document.querySelectorAll('.sd-btn').forEach(b => b.classList.toggle('active', b.getAttribute('onclick')?.includes(`'${name}'`)));
        
        document.getElementById('tb-title').textContent = name.split('-')[0].charAt(0).toUpperCase() + name.split('-')[0].slice(1);
        render();
    }

    function openPlaylist(id) { S.activePlId = id; nav('playlist'); }
    function openArtistDetail(id) { S.activeArtistId = id; nav('artist-detail'); }

    // --- RENDER ---
    function render() {
        document.getElementById('tb-count').textContent = `${allSongs.length} Tracks`;
        if (S.tab === 'home') renderHome();
        if (S.tab === 'search') renderSearch();
        if (S.tab === 'library') renderLibrary();
        if (S.tab === 'playlist') renderPlaylistView();
        if (S.tab === 'artist-detail') renderArtistDetailView();
        renderSidebarPlaylists();
    }

    function renderHome() {
        const list = document.getElementById('home-list');
        list.innerHTML = allSongs.slice(0, 15).map(s => tlHTML(s)).join('');
        const artistSection = document.getElementById('artist-album-section');
        const grid = document.getElementById('artist-grid');
        if (artistAlbums.length > 0) {
            artistSection.style.display = 'block';
            grid.innerHTML = artistAlbums.map(aa => `
                <div class="artist-card" onclick="openArtistDetail('${aa.id}')">
                    <div class="artist-thumb"><img src="${aa.imgUrl}" loading="lazy"></div>
                    <div class="artist-name">${aa.name}</div>
                </div>
            `).join('');
        }
        document.getElementById('home-visitor-footer').textContent = `Total Visits: ${visitCount}`;
    }

    function renderSearch() { filterSongs(); }
    function filterSongs() {
        const q = document.getElementById('search-inp').value.toLowerCase();
        const list = document.getElementById('search-list');
        const results = allSongs.filter(s => s.title.toLowerCase().includes(q) || s.artist.toLowerCase().includes(q));
        list.innerHTML = results.map(s => tlHTML(s)).join('');
    }

    function renderLibrary() {
        const list = document.getElementById('lib-list');
        let html = `<div class="tl-item" onclick="openPlaylist('liked')"><div class="tl-thumb" style="background:linear-gradient(135deg, #450af5, #c4efd9); color:#fff;"><i class="ri-heart-fill"></i></div><div class="tl-info"><div class="tl-name">Liked Songs</div><div class="tl-artist">Playlist • ${S.liked.size} tracks</div></div></div>`;
        html += S.playlists.map(pl => `<div class="tl-item" onclick="openPlaylist('${pl.id}')"><div class="tl-thumb" style="background:var(--s3); color:var(--text2);"><i class="ri-play-list-2-line"></i></div><div class="tl-info"><div class="tl-name">${pl.name}</div><div class="tl-artist">Playlist • ${pl.tracks.length} tracks</div></div></div>`).join('');
        html += artistAlbums.map(aa => `<div class="tl-item" onclick="openArtistDetail('${aa.id}')"><div class="tl-thumb" style="border-radius: 50%;"><img src="${aa.imgUrl}"></div><div class="tl-info"><div class="tl-name">${aa.name}</div><div class="tl-artist">Artist Collection</div></div></div>`).join('');
        list.innerHTML = html;
    }

    function renderPlaylistView() {
        const pl = S.activePlId === 'liked' ? { name: 'Liked Songs', tracks: Array.from(S.liked) } : S.playlists.find(p => p.id == S.activePlId);
        if (!pl) return nav('library');
        document.getElementById('pl-name').textContent = pl.name;
        document.getElementById('pl-meta').textContent = `${pl.tracks.length} songs`;
        const songs = pl.tracks.map(id => allSongs.find(s => s.public_id === id)).filter(Boolean);
        document.getElementById('pl-list').innerHTML = songs.map(s => tlHTML(s)).join('');
    }

    function renderArtistDetailView() {
        const aa = artistAlbums.find(a => a.id === S.activeArtistId);
        if (!aa) return nav('home');
        document.getElementById('ad-name').textContent = aa.name;
        document.getElementById('ad-meta').textContent = `${aa.tracks.length} tracks found`;
        document.getElementById('ad-thumb').innerHTML = `<img src="${aa.imgUrl}" style="width:100%; height:100%; object-fit:cover;">`;
        document.getElementById('ad-list').innerHTML = aa.tracks.map(s => tlHTML(s)).join('');
    }

    function renderSidebarPlaylists() {
        const el = document.getElementById('sd-pl-list');
        el.innerHTML = S.playlists.map(pl => `<button class="sd-btn ${S.activePlId == pl.id ? 'active' : ''}" onclick="openPlaylist('${pl.id}')"><i class="ri-music-line"></i> ${pl.name}</button>`).join('');
    }

    function tlHTML(s) {
        const active = S.queue[S.idx]?.public_id === s.public_id;
        return `<div class="tl-item" onclick="playSong('${s.public_id}')"><div class="tl-thumb"><img src="${s.imgUrl}" alt="art"></div><div class="tl-info"><div class="tl-name ${active ? 'active' : ''}">${s.title}</div><div class="tl-artist">${s.artist}</div></div><button class="tl-more" onclick="openSheet(event, '${s.public_id}')"><i class="ri-more-2-fill"></i></button></div>`;
    }

    // --- PLAYER ---
    function playSong(id) {
        const index = S.queue.findIndex(s => s.public_id === id);
        if (index === -1) {
            const s = allSongs.find(x => x.public_id === id);
            S.queue = [s, ...allSongs.filter(x => x.public_id !== id)];
            S.idx = 0;
        } else { S.idx = index; }
        const track = S.queue[S.idx];
        if (track.url !== "#") aud.src = track.url;
        aud.play().catch(() => {});
        S.playing = true;
        document.getElementById('mini-player').classList.add('show');
        updateUI();
        render();
    }

    function togglePlay(e) {
        if (e) e.stopPropagation();
        if (aud.paused) { aud.play().catch(() => {}); S.playing = true; }
        else { aud.pause(); S.playing = false; }
        updateUI();
    }

    function nextTrack() { if (S.queue.length > 0) { S.idx = (S.idx + 1) % S.queue.length; playSong(S.queue[S.idx].public_id); } }
    function prevTrack() { if (S.queue.length > 0) { S.idx = (S.idx - 1 + S.queue.length) % S.queue.length; playSong(S.queue[S.idx].public_id); } }

    function updateUI() {
        const track = S.queue[S.idx];
        if (!track) return;
        const pIco = S.playing ? 'ri-pause-fill' : 'ri-play-fill';
        document.getElementById('mp-play-ico').className = pIco;
        document.getElementById('fp-play-ico').className = pIco;
        document.getElementById('mp-title').textContent = track.title;
        document.getElementById('mp-artist').textContent = track.artist;
        document.getElementById('fp-title').textContent = track.title;
        document.getElementById('fp-artist').textContent = track.artist;
        document.getElementById('mp-thumb-container').innerHTML = `<img src="${track.imgUrl}" style="width:100%; height:100%; object-fit:cover;">`;
        document.getElementById('fp-art').innerHTML = `<img src="${track.imgUrl}" alt="art">`;
        const liked = S.liked.has(track.public_id);
        document.getElementById('fp-like-btn').innerHTML = liked ? '<i class="ri-heart-fill" style="color:var(--green)"></i>' : '<i class="ri-heart-line"></i>';
    }

    aud.ontimeupdate = () => {
        if (!aud.duration) return;
        const pct = (aud.currentTime / aud.duration) * 100;
        document.getElementById('mp-fill').style.width = pct + '%';
        document.getElementById('fp-fill-lg').style.width = pct + '%';
        document.getElementById('fp-cur').textContent = fmt(aud.currentTime);
        document.getElementById('fp-dur').textContent = fmt(aud.duration);
    };

    aud.onended = () => S.loop ? aud.play() : nextTrack();

    function seekAt(e) {
        if (!aud.duration) return;
        const r = e.currentTarget.getBoundingClientRect();
        const pct = (e.clientX - r.left) / r.width;
        aud.currentTime = pct * aud.duration;
    }

    function toggleShuffle() { S.shuffle = !S.shuffle; document.getElementById('fp-shuf').style.color = S.shuffle ? 'var(--green)' : ''; }
    function toggleLoop() { S.loop = !S.loop; document.getElementById('fp-loop').style.color = S.loop ? 'var(--green)' : ''; }

    function openModal(type, songId) { document.getElementById('modal-bg').style.display = 'flex'; S.targetSongId = songId; }
    function closeModal() { document.getElementById('modal-bg').style.display = 'none'; }
    function confirmModal() {
        const name = document.getElementById('modal-inp').value.trim();
        if (!name) return;
        const newPl = { id: Date.now(), name, tracks: S.targetSongId ? [S.targetSongId] : [] };
        S.playlists.push(newPl);
        localStorage.setItem('auraPlaylists', JSON.stringify(S.playlists));
        closeModal(); render(); toast("Playlist created!");
    }

    function toggleLike() {
        const track = S.queue[S.idx];
        if (!track) return;
        if (S.liked.has(track.public_id)) S.liked.delete(track.public_id);
        else S.liked.add(track.public_id);
        localStorage.setItem('auraLikes', JSON.stringify(Array.from(S.liked)));
        updateUI();
    }

    function openSheet(e, id) {
        e.stopPropagation(); S.targetSongId = id;
        const song = allSongs.find(s => s.public_id === id);
        const body = document.getElementById('sheet-body');
        body.innerHTML = `<div class="sheet-track"><div class="st-thumb"><img src="${song.imgUrl}"></div><div><div style="font-weight:700;">${song.title}</div><div style="color:var(--text2); font-size:13px;">${song.artist}</div></div></div><div class="sheet-item" onclick="addToPlaylistMenu()"><i class="ri-folder-add-line"></i> Add to Playlist</div>`;
        document.getElementById('sheet-bg').style.display = 'block';
        document.getElementById('sheet').classList.add('open');
    }

    function closeSheet() { document.getElementById('sheet').classList.remove('open'); setTimeout(() => document.getElementById('sheet-bg').style.display = 'none', 300); }
    
    function addToPlaylistMenu() {
        const body = document.getElementById('sheet-body');
        let html = '<div style="padding:10px 24px; font-weight:800; opacity:0.5; font-size:12px; text-transform:uppercase;">Select Playlist</div>';
        html += S.playlists.map(p => `<div class="sheet-item" onclick="addSongToPl('${p.id}')"><i class="ri-music-2-line"></i> ${p.name}</div>`).join('');
        html += `<div class="sheet-item" onclick="closeSheet(); openModal('playlist', '${S.targetSongId}')"><i class="ri-add-line"></i> New Playlist</div>`;
        body.innerHTML = html;
    }

    function addSongToPl(plId) {
        const pl = S.playlists.find(p => p.id == plId);
        if (pl && !pl.tracks.includes(S.targetSongId)) {
            pl.tracks.push(S.targetSongId);
            localStorage.setItem('auraPlaylists', JSON.stringify(S.playlists));
            toast(`Added to ${pl.name}`);
        }
        closeSheet();
    }

    function fmt(s) { if (!s) return "0:00"; const m = Math.floor(s/60); const sc = Math.floor(s%60); return m + ":" + (sc < 10 ? "0"+sc : sc); }
    function toast(msg) { const t = document.getElementById('toast'); t.textContent = msg; t.classList.add('show'); setTimeout(() => t.classList.remove('show'), 2000); }
    function openFullPlayer() { document.getElementById('full-player').classList.add('open'); }
    function closeFullPlayer() { document.getElementById('full-player').classList.remove('open'); }

    nav('home');
</script>
</body>
</html>
